@page "/productos"
@using BlazorHybridTP4.Models
@using BlazorHybridTP4.Services
@inject IProductService productService

<h3>Gestión de Productos - Platzi Fake API</h3>

<div class="card my-4 p-3 bg-light">
    <h5>Agregar Nuevo Producto</h5>
    <div class="row g-3">
        <div class="col-md-4">
            <input type="text" class="form-control" placeholder="Título del producto" @bind="nuevoProducto.Title" />
        </div>
        <div class="col-md-2">
            <input type="number" class="form-control" placeholder="Precio" @bind="nuevoProducto.Price" />
        </div>
        <div class="col-md-4">
            <input type="text" class="form-control" placeholder="Descripción" @bind="nuevoProducto.Description" />
        </div>
        <div class="col-md-2">
            <button class="btn btn-success w-100" @onclick="CrearProducto">Guardar</button>
        </div>
    </div>
    @if (!string.IsNullOrEmpty(mensajeFeedback))
    {
        <div class="alert alert-success mt-2 p-2">@mensajeFeedback</div>
    }
</div>

@if (productos == null)
{
    <div class="alert alert-info">Cargando productos...</div>
}
else if (!productos.Any())
{
    <div class="alert alert-warning">No se encontraron productos.</div>
}
else
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Título</th>
                <th>Precio</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var prod in productos)
            {
                <tr>
                    <td>@prod.Id</td>
                    <td>@prod.Title</td>
                    <td>$@prod.Price</td>
                    <td>
                        <button class="btn btn-sm btn-danger" @onclick="() => EliminarProducto(prod.Id)">
                            Eliminar
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<Product> productos;
    private Product nuevoProducto = new Product();
    private string mensajeFeedback = "";

    protected override async Task OnInitializedAsync()
    {
        ResetFormulario();
        await CargarProductos();
    }

    private async Task CargarProductos()
    {
        productos = await productService.GetProductsAsync();
    }

    private async Task CrearProducto()
    {
        if (string.IsNullOrEmpty(nuevoProducto.Title) || nuevoProducto.Price <= 0) return;

        var resultado = await productService.CreateProductAsync(nuevoProducto);
        if (resultado != null)
        {
            mensajeFeedback = $"¡Producto '{resultado.Title}' creado con éxito (ID: {resultado.Id})!";
            ResetFormulario();
            await CargarProductos(); // Recarga la lista
        }
    }

    private async Task EliminarProducto(int id)
    {
        var exito = await productService.DeleteProductAsync(id);
        if (exito)
        {
            mensajeFeedback = $"Producto ID {id} eliminado correctamente.";
            await CargarProductos();
        }
    }

    private void ResetFormulario()
    {
        nuevoProducto = new Product
            {
                Title = "",
                Price = 0,
                Description = "Descripción por defecto del TP4",
                Images = new string[] { "https://placeimg.com/640/480/any" }, // Platzi exige al menos una URL de imagen
                CategoryId = 1 // ID de categoría por defecto requerido por la API
            };
    }
}